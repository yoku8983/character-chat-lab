version = 0.1

[default.build.parameters]
cached = true
parallel = true

[default.deploy.parameters]
stack_name = "character-chat-lab-v01"
resolve_s3 = true
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
region = "us-east-1"
parameter_overrides = "DefaultCharacterId=default MessageHistoryLimit=20 BedrockModelId=us.anthropic.claude-haiku-4-5-20251001-v1:0 BedrockModelResourceArn=* BedrockMaxTokens=512 BedrockTemperature=0.4"
