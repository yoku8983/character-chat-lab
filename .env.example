# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# libSQL/Turso Database (optional)
# ローカル開発: 未設定で ./data/chat-lab.db を自動使用
# Turso: libsql://your-db-name.turso.io
# LIBSQL_URL=file:./data/chat-lab.db
# LIBSQL_AUTH_TOKEN=your_turso_auth_token

# チャット履歴の上限（直近メッセージ数）。system プロンプト+few-shot は常に保持し、
# これを超えた古い user/assistant 履歴をサーバ側で落とす。未設定なら 30。
# CHAT_MAX_HISTORY_MESSAGES=30

# LLM-as-Judge に使うモデル（未設定なら google/gemini-3.1-flash-lite）
# EVAL_JUDGE_MODEL=google/gemini-3.1-flash-lite
